# Clerk auth keys — https://dashboard.clerk.com/last-active?path=api-keys
# Use pk_test_/sk_test_ locally and pk_live_/sk_live_ on Vercel production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# MongoDB Atlas connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/projectbook)
# Atlas Network Access must allow Vercel's egress — simplest: allow 0.0.0.0/0 on the cluster.
MONGODB_URI=

# Vercel Blob read/write token — https://vercel.com/docs/storage/vercel-blob
# On Vercel, create a Blob store in the project and connect it; the token is auto-injected.
BLOB_READ_WRITE_TOKEN=

# LOCAL DEV ONLY: public URL the Vercel Blob webhook should POST back to (use ngrok/localtunnel).
# Leave UNSET on Vercel — the deployment URL is auto-detected from the request.
VERCEL_BLOB_CALLBACK_URL=

# Public Vapi/ElevenLabs assistant id used by the voice chat frontend
NEXT_PUBLIC_ASSISTANT_ID=

# Vapi Web SDK public API key (used by the browser voice client)
NEXT_PUBLIC_VAPI_API_KEY=

# Server-side shared secret that Vapi must send as header `x-vapi-secret` on tool webhooks.
# REQUIRED on Vercel for the search-book tool to authenticate; set the same value in the
# Vapi dashboard as a custom header on the tool endpoint.
VAPI_WEBHOOK_SECRET=
